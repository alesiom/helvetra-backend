# Helvetra Backend Environment Configuration
# Copy this file to .env and fill in your values

# Database (local dev only - use secure credentials in production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/helvetra

# Redis
REDIS_URL=redis://localhost:6379

# Infomaniak AI API (Apertus)
APERTUS_API_BASE=https://api.infomaniak.com/2/ai/106457/openai/v1
APERTUS_API_KEY=your_api_key_here
APERTUS_MODEL=swiss-ai/Apertus-70B-Instruct-2509

# Environment
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# PII Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Authentication
JWT_SECRET_KEY=your_jwt_secret_here

# Payrexx (payments)
PAYREXX_INSTANCE=your_instance_name
PAYREXX_API_SECRET=your_api_secret
PAYREXX_PRODUCT_PRO_ID=
PAYREXX_PRODUCT_BUSINESS_ID=

# Email (SMTP)
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_USER=no-reply@helvetra.ch
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@helvetra.ch
SMTP_FROM_NAME=Helvetra
EMAIL_VERIFICATION_BASE_URL=https://helvetra.ch/verify-email
