# Helvetra Backend Environment Configuration
# Copy to .env and fill in your values. In production (DEBUG=false) the app
# refuses to boot if any secret is missing or shorter than its minimum length.

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/helvetra

# Redis
REDIS_URL=redis://localhost:6379

# Infomaniak AI API (Apertus)
APERTUS_API_BASE=https://api.infomaniak.com/2/ai/YOUR_PRODUCT_ID/openai/v1
APERTUS_API_KEY=your_api_key_here
APERTUS_MODEL=swiss-ai/Apertus-70B-Instruct-2509

# Environment
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# PII Encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# JWT signing secret (HS256). Must be at least 32 bytes in prod.
# Generate with: openssl rand -base64 48
JWT_SECRET_KEY=

# Stripe (consumer + B2B). Use sk_test_* / whsec_* in dev.
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_MONTHLY_ID=price_xxx
STRIPE_PRICE_YEARLY_ID=price_xxx

# Stripe B2B — resolved at runtime via lookup keys, not raw price IDs,
# so price rotations in the Stripe Dashboard don't require code/env changes.
STRIPE_B2B_STARTER_BASE_LOOKUP=b2b_starter_base
STRIPE_B2B_STARTER_OVERAGE_LOOKUP=b2b_starter_overage
STRIPE_B2B_BUSINESS_BASE_LOOKUP=b2b_business_base
STRIPE_B2B_BUSINESS_OVERAGE_LOOKUP=b2b_business_overage
STRIPE_B2B_METER_EVENT_NAME=helvetra_chars_translated

# Apple Sign-In + StoreKit 2
# StoreKit verifier is kill-switched until the proper x5c chain validation
# lands — leave APPLE_STOREKIT_ENABLED=false for now.
APPLE_BUNDLE_ID=ch.helvetra.app
APPLE_STOREKIT_ENABLED=false
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=  # contents of the .p8 file
APPLE_APP_STORE_ENVIRONMENT=sandbox  # sandbox or production

# Email (SMTP)
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@yourdomain.ch
SMTP_FROM_NAME=Helvetra
EMAIL_VERIFICATION_BASE_URL=https://yourdomain.ch/verify-email
